{
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "vite",
    "build": "deno task content && vite build",
    "compile": "deno compile --include static --include _fresh --include deno.json -A --output server _fresh/compiled-entry.js",
    "start": "deno serve -A --port 8100 _fresh/server.js",
    "preview": "deno serve -A --port 8100 _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "content": "deno run -A scripts/build-content.ts",
    "check": "deno fmt --check && deno lint && deno check .",
    "verify:visual": "deno run -A scripts/visual-verify.ts",
    "verify:visual:test": "deno test -A scripts/visual_plan_test.ts"
  },
  "imports": {
    "@/": "./",
    "playwright": "npm:playwright@^1.50.0",
    "@fontsource/jetbrains-mono": "npm:@fontsource/jetbrains-mono@^5.1.0",
    "@fontsource/roboto": "npm:@fontsource/roboto@^5.1.0",
    "@fontsource/rozha-one": "npm:@fontsource/rozha-one@^5.1.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/front-matter": "jsr:@std/front-matter@^1",
    "@std/http": "jsr:@std/http@^1.1.1",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "fresh/runtime": "jsr:@fresh/core@^2.3.3/runtime",
    "mdast-util-to-string": "npm:mdast-util-to-string@^4",
    "preact": "npm:preact@^10.27.2",
    "preact/hooks": "npm:preact@^10.27.2/hooks",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "remark-directive": "npm:remark-directive@^3",
    "remark-parse": "npm:remark-parse@^11",
    "unified": "npm:unified@^11",
    "vite": "npm:vite@^7.1.3"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  },
  "exclude": [
    "example/",
    "_fresh/",
    "node_modules/"
  ],
  "fmt": {
    "exclude": ["example/", "docs/superpowers/plans/"]
  },
  "lint": {
    "exclude": ["example/", ".claude/hooks/"]
  }
}
